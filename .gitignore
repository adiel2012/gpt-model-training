# ============================================================
#  .gitignore — gpt-model-training
# ============================================================

# ── Python ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
pip-log.txt
pip-delete-this-directory.txt
.eggs/
*.egg-info/
*.egg
dist/
build/
wheels/
sdist/
var/
*.manifest
*.spec
MANIFEST

# Virtual environments
.venv/
venv/
env/
ENV/
.env
.env.*
!.env.example
conda-env/
.conda/

# Jupyter
.ipynb_checkpoints/
*.ipynb
!llm_implementations.ipynb
profile_default/
ipython_config.py

# ── PyTorch / ML artefacts ───────────────────────────────────
# Model weights & checkpoints
*.pt
*.pth
*.bin
*.safetensors
*.ckpt
*.gguf
*.ggml
checkpoints/
checkpoint-*/
runs/
outputs/
output/
logs/
wandb/
mlruns/
lightning_logs/

# Hugging Face cache (large, not repo-worthy)
.cache/
huggingface/
hf_cache/

# Dataset caches & processed splits
data/cache/
data/processed/
data/raw/
*.arrow
*.parquet
*.feather
*.jsonl.gz
*.jsonl.zst

# GGUF / quantized model shards
*.q4_0.bin
*.q8_0.bin
*-00001-of-*.safetensors

# Training artefacts
trainer_state.json
training_args.bin
special_tokens_map.json
tokenizer.model
tokenizer_config.json
vocab.json
merges.txt
added_tokens.json
optimizer.pt
scheduler.pt
scaler.pt
rng_state*.pth
zero_to_fp32.py

# TensorBoard
events.out.tfevents.*
tf_logs/

# ── LaTeX build artefacts ────────────────────────────────────
book/*.aux
book/*.bbl
book/*.bcf
book/*.blg
book/*.fdb_latexmk
book/*.fls
book/*.idx
book/*.ilg
book/*.ind
book/*.lof
book/*.log
book/*.lot
book/*.nav
book/*.out
book/*.run.xml
book/*.snm
book/*.synctex.gz
book/*.toc
book/*.vrb
book/*.xdv
book/chapters/*.aux

# Keep the compiled PDF and source, ignore build noise
# (remove the next two lines if you don't want to track PDFs)
# book/main.pdf
# book/Training_Production_Ready_LLMs_2026.pdf

# Helper scripts used only during development
book/split_chapters.py
book/add_citations.py

# ── Configs with secrets ─────────────────────────────────────
*.yaml.secret
secrets.yaml
secrets.json
.secrets
credentials.json
service_account*.json
gcp_key*.json
aws_credentials
.aws/

# API keys accidentally placed in config files
configs/*secret*
configs/*private*

# ── OS / Editor noise ────────────────────────────────────────
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~

# VSCode
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example

# JetBrains / PyCharm
.idea/
*.iml
*.iws
*.ipr

# Vim / Emacs
*.swp
*.swo
*~
\#*\#
.#*

